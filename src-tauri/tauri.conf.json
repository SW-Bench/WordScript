{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordScript",
  "version": "0.2.2-alpha",
  "identifier": "io.github.swbench.wordscript",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "overlay",
        "title": "WordScript",
        "url": "index.html#/overlay",
        "width": 236,
        "height": 44,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "WordScript – Settings",
        "url": "index.html#/settings",
        "width": 880,
        "height": 620,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      },
      {
        "label": "rebuild-lab",
        "title": "WordScript – Diagnostics",
        "url": "index.html#/rebuild-lab",
        "width": 960,
        "height": 720,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1", "libxdo3"]
      }
    }
  }
}
